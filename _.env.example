# ═══════════════════════════════════════════════════════
# VIRAL STUDIO BACKEND — ENVIRONMENT VARIABLES
# Add these in Netlify Dashboard → Site Settings → Environment Variables
# NEVER commit this file to GitHub with real values
# ═══════════════════════════════════════════════════════

# Your Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase Project URL (from Supabase → Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase Service Role Key (from Supabase → Settings → API → service_role)
# WARNING: Keep this secret — it bypasses row level security
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe Secret Key (from stripe.com → Developers → API Keys)
# Only needed when you add Stripe payments
STRIPE_SECRET_KEY=sk_live_your-stripe-key

# Stripe Webhook Secret (from Stripe → Webhooks → your endpoint → signing secret)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ═══════════════════════════════════════════════════════
# HOW TO SET THESE IN NETLIFY:
# 1. Go to app.netlify.com → your site → Site Settings
# 2. Click "Environment Variables"
# 3. Add each key above with its real value
# 4. Redeploy your site
# ═══════════════════════════════════════════════════════
